{
	"info": {
		"_postman_id": "erpnext-ecommerce-integration",
		"name": "ERPNext E-Commerce API",
		"description": "Complete API collection for e-commerce integration with ERPNext",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"auth": {
		"type": "apikey",
		"apikey": [
			{
				"key": "value",
				"value": "token {{api_key}}:{{api_secret}}",
				"type": "string"
			},
			{
				"key": "key",
				"value": "Authorization",
				"type": "string"
			}
		]
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://127.0.0.1:8002",
