		},
		{
			"key": "api_key",
			"value": "your_api_key",
			"type": "string"
		},
		{
			"key": "api_secret",
			"value": "your_api_secret",
			"type": "string"
		},
		{
			"key": "api_path",
			"value": "/api/method/erpnext.erpnext_integrations.ecommerce_api.api",
			"type": "string"
		}
