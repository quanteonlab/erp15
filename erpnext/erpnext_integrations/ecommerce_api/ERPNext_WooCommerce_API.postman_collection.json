			"item": [
				{
					"name": "Ping API",
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}{{api_path}}.ping",
							"host": ["{{base_url}}"],
							"path": ["{{api_path}}.ping"]
						},
						"description": "Health check endpoint - no authentication required"
					}
				}
			]
		},
